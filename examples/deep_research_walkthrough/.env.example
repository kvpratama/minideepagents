# --- LLM model selection (used by all 5 stages) ----------------------------
# Format: <provider>:<model-id>
# init_chat_model infers the provider from the prefix and reads the
# matching API key from environment (ANTHROPIC_API_KEY, OPENAI_API_KEY, ...).
MODEL=openai:o1-mini

# --- Provider credentials (set the one matching your MODEL) ----------------
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# --- Web search (REQUIRED — every stage uses tavily_search) ----------------
TAVILY_API_KEY=your_tavily_api_key_here

# --- Optional: override credentials / endpoint for proxies & self-hosting --
# Use these only when you need to override what init_chat_model picks up
# automatically (e.g. Azure, Bedrock, Ollama, vLLM).
# MODEL_PROVIDER=openai
# BASE_URL=http://localhost:11434/v1
# API_KEY=sk-...
# TEMPERATURE=0.0

# --- LangSmith tracing (optional but highly recommended for Studio) --------
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=deep-research-walkthrough
