# ─── Model ────────────────────────────────────────────────────────────────────
# LangChain provider:model string.  Stages 02-08 use this to build the LLM.
# Change the line below to switch providers — no code edits needed.

MODEL=anthropic:claude-sonnet-4-5-20250929

# ─── Provider API keys ───────────────────────────────────────────────────────
# Uncomment the key that matches your MODEL provider.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── Optional: LangSmith tracing ─────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
